<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-mysql-shell-for-vs-code</id>
    <version>0.0.0</version>
    <title>MySQL Shell for VS Code</title>
    <authors>Oracle</authors>
    <projectUrl>https://github.com/mysql/mysql-shell-plugins</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://Oracle.gallerycdn.vsassets.io/extensions/oracle/mysql-shell-for-vs-code/2026.5.0/1780328255347/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=Oracle.mysql-shell-for-vs-code</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>The power of MySQL Shell as part of your VS Code workflow.</description>
    <summary>The power of MySQL Shell as part of your VS Code workflow.</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=Oracle.mysql-shell-for-vs-code#changelog</releaseNotes>
    <tags>vscode extension mysql-shell-for-vs-code</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>
