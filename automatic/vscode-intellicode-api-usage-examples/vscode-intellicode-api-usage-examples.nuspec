<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-intellicode-api-usage-examples</id>
    <version>0.0.0</version>
    <title>IntelliCode API Usage Examples</title>
    <authors>VisualStudioExptTeam</authors>
    <projectUrl>https://github.com/MicrosoftDocs/intellicode</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://VisualStudioExptTeam.gallerycdn.vsassets.io/extensions/visualstudioexptteam/intellicode-api-usage-examples/0.2.9/1729726308726/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=visualstudioexptteam.intellicode-api-usage-examples</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>See relevant code examples from GitHub for over 100K different APIs right in your editor.</description>
    <summary>See relevant code examples from GitHub for over 100K different APIs right in your editor.</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=visualstudioexptteam.intellicode-api-usage-examples#changelog</releaseNotes>
    <tags>vscode extension intellicode-api-usage-examples</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>
