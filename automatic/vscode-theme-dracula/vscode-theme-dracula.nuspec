<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-theme-dracula</id>
    <version>0.0.0</version>
    <title>Visual Studio Code Extension - Dracula Theme Official</title>
    <authors>dracula-theme</authors>
    <projectUrl>https://github.com/dracula/visual-studio-code.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://dracula-theme.gallerycdn.vsassets.io/extensions/dracula-theme/theme-dracula/2.25.1/1721220788613/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=dracula-theme.theme-dracula</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description><![CDATA[
The official Dracula Theme: a dark theme for many editors, shells, and more. 🦇
]]></description>
    <summary>The official Dracula Theme: a dark theme for many editors, shells, and more. 🦇</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=dracula-theme.theme-dracula#changelog</releaseNotes>
    <tags>vscode extension theme-dracula</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="icon.png" target="." />
  </files>
</package>