<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-es7-react-js-snippets</id>
    <version>0.0.0</version>
    <title>Visual Studio Code Extension - ES7+ React/Redux/React-Native snippets</title>
    <authors>dsznajder</authors>
    <projectUrl>https://github.com/dsznajder/vscode-es7-javascript-react-snippets.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://dsznajder.gallerycdn.vsassets.io/extensions/dsznajder/es7-react-js-snippets/4.4.3/1645189962576/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=dsznajder.es7-react-js-snippets</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description><![CDATA[
Extensions for React, React-Native and Redux in JS/TS with ES7+ syntax. Customizable. Built-in integration with prettier.
]]></description>
    <summary>Extensions for React, React-Native and Redux in JS/TS with ES7+ syntax. Customizable. Built-in integration with prettier.</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=dsznajder.es7-react-js-snippets#changelog</releaseNotes>
    <tags>vscode extension es7-react-js-snippets</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="icon.png" target="." />
  </files>
</package>