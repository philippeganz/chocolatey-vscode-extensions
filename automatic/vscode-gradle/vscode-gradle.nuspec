<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-gradle</id>
    <version>0.0.0</version>
    <title>Gradle for Java</title>
    <authors>vscjava</authors>
    <projectUrl>https://github.com/microsoft/vscode-gradle/</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://vscjava.gallerycdn.vsassets.io/extensions/vscjava/vscode-gradle/3.17.2026062602/1782442737167/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=vscjava.vscode-gradle</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Manage Gradle Projects, run Gradle tasks and provide better Gradle file authoring experience in VS Code</description>
    <summary>Manage Gradle Projects, run Gradle tasks and provide better Gradle file authoring experience in VS Code</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=vscjava.vscode-gradle#changelog</releaseNotes>
    <tags>vscode extension gradle</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>