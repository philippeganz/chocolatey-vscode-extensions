<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-phptools-vscode</id>
    <version>0.0.0</version>
    <title>Visual Studio Code Extension - PHP</title>
    <authors>DEVSENSE</authors>
    <projectUrl>https://github.com/DEVSENSE/phptools-docs.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://DEVSENSE.gallerycdn.vsassets.io/extensions/devsense/phptools-vscode/1.71.19071/1784033019274/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=devsense.phptools-vscode</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description><![CDATA[
All-in-One PHP support - IntelliSense, Debug, Formatter, Code Lenses, Code Fixes, Linting, Refactoring, PHPUnit Tests, Web Server, and more.
]]></description>
    <summary>All-in-One PHP support - IntelliSense, Debug, Formatter, Code Lenses, Code Fixes, Linting, Refactoring, PHPUnit Tests, Web Server, and more.</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=devsense.phptools-vscode#changelog</releaseNotes>
    <tags>vscode extension phptools-vscode</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />       <dependency id="vscode-intelli-php-vscode" />
      <dependency id="vscode-composer-php-vscode" />
      <dependency id="vscode-profiler-php-vscode" />
 </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="icon.png" target="." />
  </files>
</package>