<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-debugpy</id>
    <version>0.0.0</version>
    <title>Python Debugger</title>
    <authors>ms-python</authors>
    <projectUrl>https://github.com/microsoft/vscode-python-debugger.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://ms-python.gallerycdn.vsassets.io/extensions/ms-python/debugpy/2026.7.11751011/1782299088041/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=ms-python.debugpy</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Python Debugger extension using debugpy.</description>
    <tags>vscode extension debugpy</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />       <dependency id="vscode-python" />
 </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>
