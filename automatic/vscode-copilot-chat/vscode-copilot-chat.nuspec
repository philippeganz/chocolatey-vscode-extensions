<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-copilot-chat</id>
    <version>0.0.0</version>
    <title>GitHub Copilot Chat</title>
    <authors>GitHub</authors>
    <projectUrl>https://github.com/microsoft/vscode-copilot-chat</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://GitHub.gallerycdn.vsassets.io/extensions/github/copilot-chat/0.48.1/1778884121163/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=GitHub.copilot-chat</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>AI chat features powered by Copilot</description>
    <tags>vscode extension copilot-chat</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>
