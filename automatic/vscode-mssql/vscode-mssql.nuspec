<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-mssql</id>
    <version>0.0.0</version>
    <title>SQL Server (mssql)</title>
    <authors>ms-mssql</authors>
    <projectUrl>https://github.com/Microsoft/vscode-mssql.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://ms-mssql.gallerycdn.vsassets.io/extensions/ms-mssql/mssql/1.43.0/1780378053147/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=ms-mssql.mssql</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Design and optimize schemas for SQL Server, Azure SQL, and SQL Database in Fabric using a modern, lightweight extension built for developers</description>
    <summary>Design and optimize schemas for SQL Server, Azure SQL, and SQL Database in Fabric using a modern, lightweight extension built for developers</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=ms-mssql.mssql#changelog</releaseNotes>
    <tags>vscode extension mssql</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />       <dependency id="vscode-data-workspace-vscode" />
      <dependency id="vscode-sql-database-projects-vscode" />
      <dependency id="vscode-sql-bindings-vscode" />
      <dependency id="vscode-dotnet-runtime" />
 </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>