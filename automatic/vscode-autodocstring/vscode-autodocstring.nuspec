<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-autodocstring</id>
    <version>0.0.0</version>
    <title>Visual Studio Code Extension - autoDocstring - Python Docstring Generator</title>
    <authors>njpwerner</authors>
    <projectUrl>https://github.com/NilsJPWerner/autoDocstring.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://njpwerner.gallerycdn.vsassets.io/extensions/njpwerner/autodocstring/0.6.1/1644940808599/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=njpwerner.autodocstring</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description><![CDATA[
Generates python docstrings automatically
]]></description>
    <summary>Generates python docstrings automatically</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=njpwerner.autodocstring#changelog</releaseNotes>
    <tags>vscode extension autodocstring</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="icon.png" target="." />
  </files>
</package>