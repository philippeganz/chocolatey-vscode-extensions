    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=usernamehw.errorlens</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description><![CDATA[
Improve highlighting of errors, warnings and other language diagnostics.
]]></description>
    <summary>Improve highlighting of errors, warnings and other language diagnostics.</summary>
