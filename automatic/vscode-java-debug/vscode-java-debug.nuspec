<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-java-debug</id>
    <version>0.0.0</version>
    <title>Debugger for Java</title>
    <authors>vscjava</authors>
    <projectUrl>https://github.com/Microsoft/vscode-java-debug.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://vscjava.gallerycdn.vsassets.io/extensions/vscjava/vscode-java-debug/0.59.2026061007/1781100744008/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=vscjava.vscode-java-debug</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>A lightweight Java debugger for Visual Studio Code</description>
    <summary>A lightweight Java debugger for Visual Studio Code</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=vscjava.vscode-java-debug#changelog</releaseNotes>
    <tags>vscode extension java-debug</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>