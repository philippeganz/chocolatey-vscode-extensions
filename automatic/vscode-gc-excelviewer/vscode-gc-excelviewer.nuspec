    <iconUrl>https://GrapeCity.gallerycdn.vsassets.io/extensions/grapecity/gc-excelviewer/4.2.66/1780672856775/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=grapecity.gc-excelviewer</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description><![CDATA[
Edit XLSX spreadsheets and CSV files in Visual Studio Code and VS Code for the Web.
]]></description>
    <summary>Edit XLSX spreadsheets and CSV files in Visual Studio Code and VS Code for the Web.</summary>
