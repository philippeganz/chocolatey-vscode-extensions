<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-dotenv</id>
    <version>0.0.0</version>
    <title>Visual Studio Code Extension - DotENV</title>
    <authors>mikestead</authors>
    <projectUrl>https://github.com/mikestead/vscode-dotenv.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://mikestead.gallerycdn.vsassets.io/extensions/mikestead/dotenv/1.0.1/1519894859412/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=mikestead.dotenv</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description><![CDATA[
Support for dotenv file syntax
]]></description>
    <summary>Support for dotenv file syntax</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=mikestead.dotenv#changelog</releaseNotes>
    <tags>vscode extension dotenv</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="icon.png" target="." />
  </files>
</package>