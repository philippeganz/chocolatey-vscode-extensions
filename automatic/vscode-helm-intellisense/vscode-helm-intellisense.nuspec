<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-helm-intellisense</id>
    <version>0.0.0</version>
    <title>Helm Intellisense</title>
    <authors>Tim-Koehler</authors>
    <projectUrl>https://github.com/tim-koehler/Helm-Intellisense</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://Tim-Koehler.gallerycdn.vsassets.io/extensions/tim-koehler/helm-intellisense/0.15.0/1746220925164/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=tim-koehler.helm-intellisense</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>This extension provides intellisense for helm templates</description>
    <summary>This extension provides intellisense for helm templates</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=tim-koehler.helm-intellisense#changelog</releaseNotes>
    <tags>vscode extension helm-intellisense</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>