<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-npm-script</id>
    <version>0.0.0</version>
    <title>Visual Studio Code Extension - npm</title>
    <authors>eg2</authors>
    <projectUrl>https://github.com/Microsoft/vscode-npm-scripts.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://eg2.gallerycdn.vsassets.io/extensions/eg2/vscode-npm-script/0.3.29/1664880784428/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=eg2.vscode-npm-script</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description><![CDATA[
npm support for VS Code
]]></description>
    <summary>npm support for VS Code</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=eg2.vscode-npm-script#changelog</releaseNotes>
    <tags>vscode extension npm-script</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="icon.png" target="." />
  </files>
