<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-rainbow-csv</id>
    <version>0.0.0</version>
    <title>Rainbow CSV</title>
    <authors>mechatroner</authors>
    <projectUrl>https://github.com/mechatroner/vscode_rainbow_csv</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://mechatroner.gallerycdn.vsassets.io/extensions/mechatroner/rainbow-csv/3.24.1/1768618250211/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=mechatroner.rainbow-csv</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Highlight CSV and TSV files, Run SQL-like queries</description>
    <summary>Highlight CSV and TSV files, Run SQL-like queries</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=mechatroner.rainbow-csv#changelog</releaseNotes>
    <tags>vscode extension rainbow-csv</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>