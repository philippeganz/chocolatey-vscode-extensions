<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-java</id>
    <version>0.0.0</version>
    <title>Language Support for Java(TM) by Red Hat</title>
    <authors>redhat</authors>
    <projectUrl>https://github.com/redhat-developer/vscode-java</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://redhat.gallerycdn.vsassets.io/extensions/redhat/java/1.55.2026062708/1782551076708/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=redhat.java</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Java Linting, Intellisense, formatting, refactoring, Maven/Gradle support and more...</description>
    <summary>Java Linting, Intellisense, formatting, refactoring, Maven/Gradle support and more...</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=redhat.java#changelog</releaseNotes>
    <tags>vscode extension java</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>