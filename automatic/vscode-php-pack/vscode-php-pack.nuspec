<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-php-pack</id>
    <version>0.0.0</version>
    <title>Visual Studio Code Extension - PHP Extension Pack</title>
    <authors>xdebug</authors>
    <projectUrl>https://github.com/zobo/vscode-php-pack.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://xdebug.gallerycdn.vsassets.io/extensions/xdebug/php-pack/1.0.3/1642771566771/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=xdebug.php-pack</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description><![CDATA[
Everything you need for PHP development
]]></description>
    <summary>Everything you need for PHP development</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=xdebug.php-pack#changelog</releaseNotes>
    <tags>vscode extension php-pack</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />       <dependency id="vscode-php-debug" />
      <dependency id="vscode-php-intellisense" />
 </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="icon.png" target="." />
  </files>
</package>