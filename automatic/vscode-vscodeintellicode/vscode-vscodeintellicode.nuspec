<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-vscodeintellicode</id>
    <version>0.0.0</version>
    <title>IntelliCode</title>
    <authors>VisualStudioExptTeam</authors>
    <projectUrl>https://github.com/MicrosoftDocs/intellicode</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://VisualStudioExptTeam.gallerycdn.vsassets.io/extensions/visualstudioexptteam/vscodeintellicode/1.3.2/1729726946695/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=VisualStudioExptTeam.vscodeintellicode</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>AI-assisted development</description>
    <summary>AI-assisted development</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=VisualStudioExptTeam.vscodeintellicode#changelog</releaseNotes>
    <tags>vscode extension vscodeintellicode</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />       <dependency id="vscode-intellicode-api-usage-examples" />
 </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>
