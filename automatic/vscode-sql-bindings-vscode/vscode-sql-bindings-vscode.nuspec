<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-sql-bindings-vscode</id>
    <version>0.0.0</version>
    <title>SQL Bindings</title>
    <authors>ms-mssql</authors>
    <projectUrl>https://github.com/Microsoft/azuredatastudio.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://ms-mssql.gallerycdn.vsassets.io/extensions/ms-mssql/sql-bindings-vscode/0.4.1/1746044873829/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=ms-mssql.sql-bindings-vscode</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Enables users to develop and publish Azure Functions with Azure SQL bindings</description>
    <summary>Enables users to develop and publish Azure Functions with Azure SQL bindings</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=ms-mssql.sql-bindings-vscode#changelog</releaseNotes>
