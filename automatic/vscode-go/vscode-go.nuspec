<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-go</id>
    <version>0.0.0</version>
    <title>Go</title>
    <authors>golang</authors>
    <projectUrl>https://github.com/golang/vscode-go</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://golang.gallerycdn.vsassets.io/extensions/golang/go/0.55.0/1781121081416/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=golang.go</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Rich Go language support for Visual Studio Code</description>
    <summary>Rich Go language support for Visual Studio Code</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=golang.go#changelog</releaseNotes>
    <tags>vscode extension go</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>
