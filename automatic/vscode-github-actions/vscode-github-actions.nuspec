<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-github-actions</id>
    <version>0.0.0</version>
    <title>GitHub Actions</title>
    <authors>github</authors>
    <projectUrl>https://github.com/github/vscode-github-actions</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://GitHub.gallerycdn.vsassets.io/extensions/github/vscode-github-actions/0.32.1/1782498285743/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=github.vscode-github-actions</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>GitHub Actions workflows and runs for github.com hosted repositories in VS Code</description>
    <summary>GitHub Actions workflows and runs for github.com hosted repositories in VS Code</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=github.vscode-github-actions#changelog</releaseNotes>
    <tags>vscode extension github-actions</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>
