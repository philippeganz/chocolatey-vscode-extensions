<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-doxdocgen</id>
    <version>0.0.0</version>
    <title>Visual Studio Code Extension - Doxygen Documentation Generator</title>
    <authors>cschlosser</authors>
    <projectUrl>https://github.com/cschlosser/doxdocgen.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://cschlosser.gallerycdn.vsassets.io/extensions/cschlosser/doxdocgen/1.4.0/1645786891772/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=cschlosser.doxdocgen</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description><![CDATA[
Let me generate Doxygen documentation from your source code for you.
]]></description>
    <summary>Let me generate Doxygen documentation from your source code for you.</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=cschlosser.doxdocgen#changelog</releaseNotes>
    <tags>vscode extension doxdocgen</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="icon.png" target="." />
  </files>
</package>