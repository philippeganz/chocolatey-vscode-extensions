<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-auto-rename-tag</id>
    <version>0.0.0</version>
    <title>Auto Rename Tag</title>
    <authors>formulahendry</authors>
    <projectUrl>https://github.com/formulahendry/vscode-auto-rename-tag.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://formulahendry.gallerycdn.vsassets.io/extensions/formulahendry/auto-rename-tag/0.1.10/1644319230173/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=formulahendry.auto-rename-tag</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Auto rename paired HTML/XML tag</description>
    <summary>Auto rename paired HTML/XML tag</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=formulahendry.auto-rename-tag#changelog</releaseNotes>
    <tags>vscode extension auto-rename-tag</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>