<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-shellcheck</id>
    <version>0.0.0</version>
    <title>ShellCheck</title>
    <authors>timonwong</authors>
    <projectUrl>https://github.com/vscode-shellcheck/vscode-shellcheck.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://timonwong.gallerycdn.vsassets.io/extensions/timonwong/shellcheck/0.39.5/1778339305104/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=timonwong.shellcheck</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Integrates ShellCheck into VS Code, a linter for Shell scripts.</description>
    <summary>Integrates ShellCheck into VS Code, a linter for Shell scripts.</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=timonwong.shellcheck#changelog</releaseNotes>
    <tags>vscode extension shellcheck</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>
