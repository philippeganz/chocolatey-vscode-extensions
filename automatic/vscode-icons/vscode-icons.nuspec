<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-icons</id>
    <version>0.0.0</version>
    <title>vscode-icons</title>
    <authors>vscode-icons-team</authors>
    <projectUrl>https://github.com/vscode-icons/vscode-icons</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://vscode-icons-team.gallerycdn.vsassets.io/extensions/vscode-icons-team/vscode-icons/12.19.0/1782585231472/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=vscode-icons-team.vscode-icons</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Icons for Visual Studio Code</description>
    <summary>Icons for Visual Studio Code</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=vscode-icons-team.vscode-icons#changelog</releaseNotes>
    <tags>vscode extension icons</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>
