<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-material-icon-theme</id>
    <version>0.0.0</version>
    <title>Material Icon Theme</title>
    <authors>PKief</authors>
    <projectUrl>git+https://github.com/material-extensions/vscode-material-icon-theme.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://PKief.gallerycdn.vsassets.io/extensions/pkief/material-icon-theme/5.36.1/1782238809254/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=PKief.material-icon-theme</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Material Design Icons for Visual Studio Code</description>
    <summary>Material Design Icons for Visual Studio Code</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=PKief.material-icon-theme#changelog</releaseNotes>
    <tags>vscode extension material-icon-theme</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>
