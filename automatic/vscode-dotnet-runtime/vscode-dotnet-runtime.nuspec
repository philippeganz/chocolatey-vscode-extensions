<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-dotnet-runtime</id>
    <version>0.0.0</version>
    <title>.NET Install Tool</title>
    <authors>ms-dotnettools</authors>
    <projectUrl>https://github.com/dotnet/vscode-dotnet-runtime.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://ms-dotnettools.gallerycdn.vsassets.io/extensions/ms-dotnettools/vscode-dotnet-runtime/3.1.0/1781201336184/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=ms-dotnettools.vscode-dotnet-runtime</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>This extension installs and manages different versions of the .NET SDK and Runtime.</description>
    <summary>This extension installs and manages different versions of the .NET SDK and Runtime.</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=ms-dotnettools.vscode-dotnet-runtime#changelog</releaseNotes>
    <tags>vscode extension dotnet-runtime</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>