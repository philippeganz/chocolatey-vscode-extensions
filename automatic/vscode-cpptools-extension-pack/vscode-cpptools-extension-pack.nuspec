<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-cpptools-extension-pack</id>
    <version>1.5.1</version>
    <title>C/C++ Extension Pack</title>
    <authors>ms-vscode</authors>
    <projectUrl>https://github.com/microsoft/vscode-cpptools.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://ms-vscode.gallerycdn.vsassets.io/extensions/ms-vscode/cpptools-extension-pack/1.5.1/1771540600646/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=ms-vscode.cpptools-extension-pack</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description><![CDATA[This extension pack includes a set of popular extensions for C++ development in Visual Studio Code:
* [C/C++](https://marketplace.visualstudio.com/items?itemName=ms-vscode.cpptools)
* [C/C++ Themes](https://marketplace.visualstudio.com/items?itemName=ms-vscode.cpptools-themes)
* [C/C++ DevTools](https://marketplace.visualstudio.com/items?itemName=ms-vscode.cpp-devtools)
* [CMake Tools](https://marketplace.visualstudio.com/items?itemName=ms-vscode.cmake-tools)
]]></description>
    <summary>Popular extensions for C++ development in Visual Studio Code.</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=ms-vscode.cpptools-extension-pack#changelog</releaseNotes>
    <tags>vscode extension cpptools-extension-pack</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />       <dependency id="vscode-cpptools" />
      <dependency id="vscode-cpptools-themes" />
      <dependency id="vscode-cpp-devtools" />
      <dependency id="vscode-cmake-tools" />
 </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>
