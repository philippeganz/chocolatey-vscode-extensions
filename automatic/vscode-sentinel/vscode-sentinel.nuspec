<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-sentinel</id>
    <version>0.0.0</version>
    <title>HashiCorp Sentinel</title>
    <authors>hashicorp</authors>
    <projectUrl>https://github.com/hashicorp/vscode-sentinel.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://HashiCorp.gallerycdn.vsassets.io/extensions/hashicorp/sentinel/0.3.0/1701786621072/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=hashicorp.sentinel</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Syntax highlighting for HashiCorp Sentinel</description>
    <summary>Syntax highlighting for HashiCorp Sentinel</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=hashicorp.sentinel#changelog</releaseNotes>
    <tags>vscode extension sentinel</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>