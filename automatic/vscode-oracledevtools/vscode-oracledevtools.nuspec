<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-oracledevtools</id>
    <version>0.0.0</version>
    <title>Oracle Developer Tools for VS Code (SQL and PLSQL)</title>
    <authors>Oracle</authors>
    <projectUrl>https://marketplace.visualstudio.com/items?itemName=Oracle.oracledevtools</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://Oracle.gallerycdn.vsassets.io/extensions/oracle/oracledevtools/23.4.1/1724949901572/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=Oracle.oracledevtools</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Develop SQL and PL/SQL with Oracle Database and Oracle Autonomous Database</description>
    <summary>Develop SQL and PL/SQL with Oracle Database and Oracle Autonomous Database</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=Oracle.oracledevtools#changelog</releaseNotes>
    <tags>vscode extension oracledevtools</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />       <dependency id="vscode-dotnet-runtime" />
 </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>
