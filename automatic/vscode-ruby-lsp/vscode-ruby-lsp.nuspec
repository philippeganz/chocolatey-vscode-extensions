<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-ruby-lsp</id>
    <version>0.0.0</version>
    <title>Visual Studio Code Extension - Ruby LSP</title>
    <authors>Shopify</authors>
    <projectUrl>https://github.com/Shopify/ruby-lsp.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://Shopify.gallerycdn.vsassets.io/extensions/shopify/ruby-lsp/0.10.4/1779312212627/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=shopify.ruby-lsp</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description><![CDATA[
VS Code plugin for connecting with the Ruby LSP
]]></description>
    <summary>VS Code plugin for connecting with the Ruby LSP</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=shopify.ruby-lsp#changelog</releaseNotes>
    <tags>vscode extension ruby-lsp</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="icon.png" target="." />
  </files>
</package>
