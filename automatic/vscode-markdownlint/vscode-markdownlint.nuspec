<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-markdownlint</id>
    <version>0.0.0</version>
    <title>markdownlint</title>
    <authors>DavidAnson</authors>
    <projectUrl>https://github.com/DavidAnson/vscode-markdownlint.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://DavidAnson.gallerycdn.vsassets.io/extensions/davidanson/vscode-markdownlint/0.61.2/1774828896376/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=davidanson.vscode-markdownlint</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Markdown linting and style checking for Visual Studio Code</description>
    <summary>Markdown linting and style checking for Visual Studio Code</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=davidanson.vscode-markdownlint#changelog</releaseNotes>
    <tags>vscode extension markdownlint</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>
