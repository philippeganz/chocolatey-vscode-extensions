<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-cmake</id>
    <version>0.0.0</version>
    <title>CMake</title>
    <authors>twxs</authors>
    <projectUrl>https://github.com/twxs/vs.language.cmake.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://twxs.gallerycdn.vsassets.io/extensions/twxs/cmake/0.0.17/1488841920286/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=twxs.cmake</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>CMake langage support for Visual Studio Code</description>
    <summary>CMake langage support for Visual Studio Code</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=twxs.cmake#changelog</releaseNotes>
    <tags>vscode extension cmake</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>