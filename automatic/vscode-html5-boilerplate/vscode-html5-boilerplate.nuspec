<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-html5-boilerplate</id>
    <version>0.0.0</version>
    <title>Visual Studio Code Extension - HTML Boilerplate</title>
    <authors>sidthesloth</authors>
    <projectUrl>https://github.com/sidthesloth92/vsc_html5_boilerplate.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://sidthesloth.gallerycdn.vsassets.io/extensions/sidthesloth/html5-boilerplate/1.1.1/1601299096251/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=sidthesloth.html5-boilerplate</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description><![CDATA[
A basic HTML5 boilerplate snippet generator.
]]></description>
    <summary>A basic HTML5 boilerplate snippet generator.</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=sidthesloth.html5-boilerplate#changelog</releaseNotes>
    <tags>vscode extension html5-boilerplate</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="icon.png" target="." />
  </files>
</package>