<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-remote-containers</id>
    <version>0.0.0</version>
    <title>Dev Containers</title>
    <authors>ms-vscode-remote</authors>
    <projectUrl>https://github.com/Microsoft/vscode-remote-release.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://ms-vscode-remote.gallerycdn.vsassets.io/extensions/ms-vscode-remote/remote-containers/0.462.0/1782407900621/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=ms-vscode-remote.remote-containers</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Open any folder or repository inside a Docker container and take advantage of Visual Studio Code&apos;s full feature set.</description>
    <summary>Open any folder or repository inside a Docker container and take advantage of Visual Studio Code&apos;s full feature set.</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=ms-vscode-remote.remote-containers#changelog</releaseNotes>
    <tags>vscode extension remote-containers</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>