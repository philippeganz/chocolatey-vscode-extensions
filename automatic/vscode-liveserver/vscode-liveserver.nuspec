<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-liveserver</id>
    <version>0.0.0</version>
    <title>Live Server</title>
    <authors>ritwickdey</authors>
    <projectUrl>https://github.com/ritwickdey/vscode-live-server.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://ritwickdey.gallerycdn.vsassets.io/extensions/ritwickdey/liveserver/5.7.10/1772184436918/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=ritwickdey.LiveServer</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Launch a development local Server with live reload feature for static &amp; dynamic pages</description>
    <summary>Launch a development local Server with live reload feature for static &amp; dynamic pages</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=ritwickdey.LiveServer#changelog</releaseNotes>
    <tags>vscode extension liveserver</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>
