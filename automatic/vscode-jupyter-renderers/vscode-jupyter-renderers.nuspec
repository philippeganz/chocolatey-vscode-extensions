<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-jupyter-renderers</id>
    <version>0.0.0</version>
    <title>Jupyter Notebook Renderers</title>
    <authors>ms-toolsai</authors>
    <projectUrl>https://github.com/Microsoft/vscode-notebook-renderers</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://ms-toolsai.gallerycdn.vsassets.io/extensions/ms-toolsai/jupyter-renderers/1.3.2025062701/1751008411968/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=ms-toolsai.jupyter-renderers</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Renderers for Jupyter Notebooks (with plotly, vega, gif, png, svg, jpeg and other such outputs)</description>
    <summary>Renderers for Jupyter Notebooks (with plotly, vega, gif, png, svg, jpeg and other such outputs)</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=ms-toolsai.jupyter-renderers#changelog</releaseNotes>
    <tags>vscode extension jupyter-renderers</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>
