<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-rust-analyzer</id>
    <version>0.0.0</version>
    <title>Visual Studio Code Extension - rust-analyzer</title>
    <authors>rust-lang</authors>
    <projectUrl>https://github.com/rust-lang/rust-analyzer.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://rust-lang.gallerycdn.vsassets.io/extensions/rust-lang/rust-analyzer/0.4.2972/1783991013235/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=rust-lang.rust-analyzer</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description><![CDATA[
Rust language support for Visual Studio Code
]]></description>
    <summary>Rust language support for Visual Studio Code</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=rust-lang.rust-analyzer#changelog</releaseNotes>
    <tags>vscode extension rust-analyzer</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="icon.png" target="." />
  </files>
