<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-remote-explorer</id>
    <version>0.0.0</version>
    <title>Remote Explorer</title>
    <authors>ms-vscode</authors>
    <projectUrl>https://github.com/Microsoft/vscode-remote-release.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://ms-vscode.gallerycdn.vsassets.io/extensions/ms-vscode/remote-explorer/0.6.2026031809/1773825461230/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=ms-vscode.remote-explorer</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>View remote machines for SSH and Tunnels.</description>
    <summary>View remote machines for SSH and Tunnels.</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=ms-vscode.remote-explorer#changelog</releaseNotes>
    <tags>vscode extension remote-explorer</tags>
    <dependencies>
