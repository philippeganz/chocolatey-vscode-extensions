<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-php-intellisense</id>
    <version>0.0.0</version>
    <title>Visual Studio Code Extension - PHP IntelliSense</title>
    <authors>felixfbecker</authors>
    <projectUrl>https://github.com/felixfbecker/vscode-php-intellisense.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://felixfbecker.gallerycdn.vsassets.io/extensions/felixfbecker/php-intellisense/2.3.14/1577384498359/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=felixfbecker.php-intellisense</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description><![CDATA[
Advanced Autocompletion and Refactoring support for PHP
]]></description>
    <summary>Advanced Autocompletion and Refactoring support for PHP</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=felixfbecker.php-intellisense#changelog</releaseNotes>
    <tags>vscode extension php-intellisense</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="icon.png" target="." />
  </files>
</package>