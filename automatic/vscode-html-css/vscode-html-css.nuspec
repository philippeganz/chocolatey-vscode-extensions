<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-html-css</id>
    <version>0.0.0</version>
    <title>HTML CSS Support</title>
    <authors>ecmel</authors>
    <projectUrl>https://github.com/ecmel/vscode-html-css.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://ecmel.gallerycdn.vsassets.io/extensions/ecmel/vscode-html-css/2.0.14/1770897391434/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=ecmel.vscode-html-css</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>CSS Intellisense for HTML</description>
    <summary>CSS Intellisense for HTML</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=ecmel.vscode-html-css#changelog</releaseNotes>
    <tags>vscode extension html-css</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>