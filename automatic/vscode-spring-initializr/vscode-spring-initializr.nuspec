<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-spring-initializr</id>
    <version>0.0.0</version>
    <title>Visual Studio Code Extension - Spring Initializr Java Support</title>
    <authors>vscjava</authors>
    <projectUrl>https://github.com/Microsoft/vscode-spring-initializr.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://vscjava.gallerycdn.vsassets.io/extensions/vscjava/vscode-spring-initializr/0.12.0/1763086464475/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=vscjava.vscode-spring-initializr</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description><![CDATA[
A lightweight extension based on Spring Initializr to generate quick start Spring Boot Java projects.
]]></description>
    <summary>A lightweight extension based on Spring Initializr to generate quick start Spring Boot Java projects.</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=vscjava.vscode-spring-initializr#changelog</releaseNotes>
    <tags>vscode extension spring-initializr</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="icon.png" target="." />
  </files>
</package>