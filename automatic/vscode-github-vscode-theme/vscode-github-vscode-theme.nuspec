<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-github-theme</id>
    <version>0.0.0</version>
    <title>Visual Studio Code Extension - GitHub Theme</title>
    <authors>GitHub</authors>
    <projectUrl>https://github.com/primer/github-vscode-theme.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://GitHub.gallerycdn.vsassets.io/extensions/github/github-vscode-theme/6.3.5/1727933603062/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=github.github-vscode-theme</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description><![CDATA[
GitHub theme for VS Code
]]></description>
    <summary>GitHub theme for VS Code</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=github.github-vscode-theme#changelog</releaseNotes>
    <tags>vscode extension github-theme</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="icon.png" target="." />
  </files>
</package>