<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-gitignore</id>
    <version>0.0.0</version>
    <title>Visual Studio Code Extension - gitignore</title>
    <authors>codezombiech</authors>
    <projectUrl>https://github.com/CodeZombieCH/vscode-gitignore.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://codezombiech.gallerycdn.vsassets.io/extensions/codezombiech/gitignore/0.10.0/1740794494947/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=codezombiech.gitignore</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description><![CDATA[
Lets you pull .gitignore templates from the https://github.com/github/gitignore repository. Language support for .gitignore files.
]]></description>
    <summary>Lets you pull .gitignore templates from the https://github.com/github/gitignore repository. Language support for .gitignore files.</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=codezombiech.gitignore#changelog</releaseNotes>
    <tags>vscode extension gitignore</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="icon.png" target="." />
  </files>
</package>