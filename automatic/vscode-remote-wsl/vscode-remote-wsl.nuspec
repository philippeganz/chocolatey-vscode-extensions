<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-remote-wsl</id>
    <version>0.0.0</version>
    <title>WSL</title>
    <authors>ms-vscode-remote</authors>
    <projectUrl>https://github.com/Microsoft/vscode-remote-release.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://ms-vscode-remote.gallerycdn.vsassets.io/extensions/ms-vscode-remote/remote-wsl/0.104.3/1759355620566/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=ms-vscode-remote.remote-wsl</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Open any folder in the Windows Subsystem for Linux (WSL) and take advantage of Visual Studio Code&apos;s full feature set.</description>
    <summary>Open any folder in the Windows Subsystem for Linux (WSL) and take advantage of Visual Studio Code&apos;s full feature set.</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=ms-vscode-remote.remote-wsl#changelog</releaseNotes>
    <tags>vscode extension remote-wsl</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>