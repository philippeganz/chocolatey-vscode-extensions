<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-pull-request-github</id>
    <version>0.0.0</version>
    <title>GitHub Pull Requests</title>
    <authors>GitHub</authors>
    <projectUrl>https://github.com/Microsoft/vscode-pull-request-github</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://GitHub.gallerycdn.vsassets.io/extensions/github/vscode-pull-request-github/0.153.2026063010/1782814448439/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=GitHub.vscode-pull-request-github</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Pull Request and Issue Provider for GitHub</description>
    <summary>Pull Request and Issue Provider for GitHub</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=GitHub.vscode-pull-request-github#changelog</releaseNotes>
    <tags>vscode extension pull-request-github</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>
