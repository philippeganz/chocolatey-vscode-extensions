<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-ansible</id>
    <version>0.0.0</version>
    <title>Ansible</title>
    <authors>redhat</authors>
    <projectUrl>git+https://github.com/ansible/vscode-ansible.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://redhat.gallerycdn.vsassets.io/extensions/redhat/ansible/26.6.0/1780306951951/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=redhat.ansible</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Ansible language support</description>
    <summary>Ansible language support</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=redhat.ansible#changelog</releaseNotes>
    <tags>vscode extension ansible</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />       <dependency id="vscode-python" />
      <dependency id="vscode-python-envs" />
      <dependency id="vscode-yaml" />
 </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>
