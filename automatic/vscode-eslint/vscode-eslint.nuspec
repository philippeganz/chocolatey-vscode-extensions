<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-eslint</id>
    <version>0.0.0</version>
    <title>ESLint</title>
    <authors>dbaeumer</authors>
    <projectUrl>https://github.com/Microsoft/vscode-eslint.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://dbaeumer.gallerycdn.vsassets.io/extensions/dbaeumer/vscode-eslint/3.0.31/1782116407798/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=dbaeumer.vscode-eslint</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Integrates ESLint JavaScript into VS Code.</description>
    <summary>Integrates ESLint JavaScript into VS Code.</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=dbaeumer.vscode-eslint#changelog</releaseNotes>
    <tags>vscode extension eslint</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>