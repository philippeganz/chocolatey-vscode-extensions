<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-python-envs</id>
    <version>0.0.0</version>
    <title>Python Environments</title>
    <authors>ms-python</authors>
    <projectUrl>https://github.com/microsoft/vscode-python-environments.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://ms-python.gallerycdn.vsassets.io/extensions/ms-python/vscode-python-envs/1.37.2026062601/1782470462192/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=ms-python.vscode-python-envs</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Provides a unified python environment experience</description>
    <summary>Provides a unified python environment experience</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=ms-python.vscode-python-envs#changelog</releaseNotes>
    <tags>vscode extension python-envs</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>
