<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-puppet-vscode</id>
    <version>0.0.0</version>
    <title>Visual Studio Code Extension - Puppet</title>
    <authors>puppet</authors>
    <projectUrl>https://github.com/puppetlabs/puppet-vscode.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://puppet.gallerycdn.vsassets.io/extensions/puppet/puppet-vscode/1.5.7/1780487930457/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=puppet.puppet-vscode</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description><![CDATA[
Official Puppet VSCode extension. Provides full Puppet DSL intellisense, syntax highlighting, Puppet command support, Puppet node graphs, and much more
]]></description>
    <summary>Official Puppet VSCode extension. Provides full Puppet DSL intellisense, syntax highlighting, Puppet command support, Puppet node graphs, and much more</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=puppet.puppet-vscode#changelog</releaseNotes>
    <tags>vscode extension puppet-vscode</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="icon.png" target="." />
  </files>
</package>
