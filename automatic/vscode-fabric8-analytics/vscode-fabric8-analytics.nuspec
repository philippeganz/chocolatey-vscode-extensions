<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-fabric8-analytics</id>
    <version>0.0.0</version>
    <title>Red Hat Dependency Analytics</title>
    <authors>redhat</authors>
    <projectUrl>https://github.com/fabric8-analytics/fabric8-analytics-vscode-extension</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://redhat.gallerycdn.vsassets.io/extensions/redhat/fabric8-analytics/1.0.0/1781174203414/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=redhat.fabric8-analytics</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Provides insights on security vulnerabilities and license compatibility in your application dependencies.</description>
    <summary>Provides insights on security vulnerabilities and license compatibility in your application dependencies.</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=redhat.fabric8-analytics#changelog</releaseNotes>
    <tags>vscode extension fabric8-analytics</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>