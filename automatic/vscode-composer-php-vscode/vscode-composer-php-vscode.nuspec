    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=devsense.composer-php-vscode</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description><![CDATA[
All-in-One composer integration, quick actions, commands, automatic installation, tasks, code lenses, diagnostics, and composer.json IntelliSense.
]]></description>
    <summary>All-in-One composer integration, quick actions, commands, automatic installation, tasks, code lenses, diagnostics, and composer.json IntelliSense.</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=devsense.composer-php-vscode#changelog</releaseNotes>
