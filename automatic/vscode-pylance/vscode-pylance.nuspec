<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-pylance</id>
    <version>0.0.0</version>
    <title>Pylance</title>
    <authors>ms-python</authors>
    <projectUrl>https://github.com/microsoft/pylance-release</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://ms-python.gallerycdn.vsassets.io/extensions/ms-python/vscode-pylance/2026.2.106/1782488767651/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=ms-python.vscode-pylance</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>A performant, feature-rich language server for Python in VS Code</description>
    <summary>A performant, feature-rich language server for Python in VS Code</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=ms-python.vscode-pylance#changelog</releaseNotes>
    <tags>vscode extension pylance</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>
