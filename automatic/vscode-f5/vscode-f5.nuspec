<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-f5</id>
    <version>0.0.0</version>
    <title>The F5 Extension</title>
    <authors>F5DevCentral</authors>
    <projectUrl>https://github.com/f5devcentral/vscode-f5.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://F5DevCentral.gallerycdn.vsassets.io/extensions/f5devcentral/vscode-f5/3.19.0/1772248236015/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=f5devcentral.vscode-f5</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Supercharge your F5 automation development</description>
    <summary>Supercharge your F5 automation development</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=f5devcentral.vscode-f5#changelog</releaseNotes>
    <tags>vscode extension f5</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>