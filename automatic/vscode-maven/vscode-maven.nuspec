<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-maven</id>
    <version>0.0.0</version>
    <title>Maven for Java</title>
    <authors>vscjava</authors>
    <projectUrl>https://github.com/Microsoft/vscode-maven.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://vscjava.gallerycdn.vsassets.io/extensions/vscjava/vscode-maven/0.45.2026052803/1780974462926/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=vscjava.vscode-maven</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Manage Maven projects, execute goals, generate project from archetype, improve user experience for Java developers.</description>
    <summary>Manage Maven projects, execute goals, generate project from archetype, improve user experience for Java developers.</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=vscjava.vscode-maven#changelog</releaseNotes>
    <tags>vscode extension maven</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>
