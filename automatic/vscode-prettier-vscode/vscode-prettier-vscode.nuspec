<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-prettier-vscode</id>
    <version>12.4.0</version>
    <title>Prettier - Code formatter</title>
    <authors>esbenp</authors>
    <projectUrl>https://github.com/prettier/prettier-vscode.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://esbenp.gallerycdn.vsassets.io/extensions/esbenp/prettier-vscode/12.4.0/1773688466128/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <license type="file">LICENSE.txt</license>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Code formatter using prettier</description>
    <tags>vscode extension prettier-vscode</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>
