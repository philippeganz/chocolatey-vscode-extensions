<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>vscode-hcl</id>
    <version>0.0.0</version>
    <title>HashiCorp HCL</title>
    <authors>hashicorp</authors>
    <projectUrl>https://github.com/hashicorp/vscode-hcl.git</projectUrl>
    <packageSourceUrl>https://github.com/philippeganz/chocolatey-vscode-extensions</packageSourceUrl>
    <iconUrl>https://HashiCorp.gallerycdn.vsassets.io/extensions/hashicorp/hcl/0.6.0/1729689056959/Microsoft.VisualStudio.Services.Icons.Default</iconUrl>
    <licenseUrl>https://marketplace.visualstudio.com/items?itemName=hashicorp.hcl</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>HashiCorp HCL syntax</description>
    <summary>HashiCorp HCL syntax</summary>
    <releaseNotes>https://marketplace.visualstudio.com/items?itemName=hashicorp.hcl#changelog</releaseNotes>
    <tags>vscode extension hcl</tags>
    <dependencies>
      <dependency id="chocolatey-vscode.extension" version="1.1.0" />  </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="README.md" target="." />
    <file src="LICENSE*" target="." />
    <file src="icon.png" target="." />
  </files>
</package>
